# Local backend port. Render provides PORT automatically in production.
PORT=<some integer>

# Frontend Vite app
# Use this in Vercel or any other hosted frontend to point at the deployed API.
VITE_API_BASE_URL=https://your-api-domain.example.com/api

# Backend CORS allowlist. Separate multiple origins with commas.
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.example.com

# Required for protected backend write routes.
# Send this value as x-admin-api-key from trusted backend/admin tooling only.
ADMIN_API_KEY=replace-with-a-long-random-secret

# Admin login password and signed cookie secret for /adminlogin.
# These are backend-only secrets. Do not prefix them with VITE_.
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-session-secret

# Supabase Postgres connection string.
# Paste the "Connection string" from your Supabase project settings.
# If DATABASE_URL is set, backend/config/db.js will use it.
DATABASE_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require"

# Optional public Supabase Storage bucket base URL for shell images.
# Example: https://your-project-ref.supabase.co/storage/v1/object/public/species-images
# If omitted, stored shell_image paths like /species-images/eburneus.jpg are used as fallback.
SUPABASE_PUBLIC_BUCKET_URL=https://your-project-ref.supabase.co/storage/v1/object/public/species-images
